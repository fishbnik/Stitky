<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Stitky.SettingsPage">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label 
                Text="Nastavení"
                FontSize="24"
                HorizontalOptions="Center"
                FontAttributes="Bold" />

            <!-- Přepínač -->
            <HorizontalStackLayout>
                <Label Text="Použít tmavý režim" VerticalOptions="Center" />
                <Switch x:Name="DarkModeSwitch" />
            </HorizontalStackLayout>

            <!-- Textové pole -->
            <Label Text="Složka s protokoly:" />
            <Entry x:Name="ExcelPath" Placeholder="Vyber složku protokolů..." />

            <!-- Tlačítko Vyber složku protokolů -->
            <Button Text="Vyber složku protokolů" Clicked="VyberSlozkyProtokolu" />

            <!-- Výstup -->
            <Label x:Name="StatusLabel" TextColor="Green" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
