<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Stitky.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="30,00" Spacing="25">
           
      
            <Label
                Text="Zadejte výrobní číslo transformátoru"
                HorizontalOptions="Center"
                SemanticProperties.HeadingLevel="Level1" />


            

            <Entry x:Name="Cislo" Placeholder="Výrobní číslo" />

            <Button Text="Načíst" Clicked="OnKlik" />

            <Label x:Name="NacteneCislo" />

              


        
        </VerticalStackLayout>
        
    </ScrollView>

</ContentPage>
