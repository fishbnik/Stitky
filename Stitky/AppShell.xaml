<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Stitky.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Stitky"
    Title="Štítky">

    <ShellContent
        Title="Načíst údaje o trafu"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />


    <!-- nastavení -->
    <ShellContent Title="Nastavení" ContentTemplate="{DataTemplate local:SettingsPage}" />

    <!-- info -->
    <ShellContent Title="Info" ContentTemplate="{DataTemplate local:InfoPage}" />

</Shell>
